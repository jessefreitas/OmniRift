{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OmniRift",
  "version": "0.1.127",
  "identifier": "com.omniforge.omnirift",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OmniRift",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "OmniForge",
    "homepage": "https://omnirift.omniforge.com.br",
    "license": "MIT",
    "category": "DeveloperTool",
    "shortDescription": "Canvas infinito para orquestrar agentes de IA, terminais e notas.",
    "longDescription": "OmniRift é um canvas infinito para orquestrar agentes de IA (Claude Code, Codex, shell), terminais PTY, sketches e notas — o equivalente open-source do Maestri para Linux e Windows. Conecte agentes entre si, organize o trabalho em workspaces e paralelos (git worktrees) e mantenha terminais, notas e navegadores num só lugar.",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/omnicompress-proxy",
      "binaries/omnicompress-mcp",
      "binaries/omnicompress"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^(https?://[^\\s\"'<>]+|mailto:[^\\s\"'<>]+|tel:[^\\s\"'<>]+|file:///[^\\s\"'<>;|&$]*)$"
    },
    "updater": {
      "endpoints": [
        "https://github.com/jessefreitas/OmniRift/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENEOUMxQTlBNzU2QUNDMEIKUldRTHpHcDFtaHFjemI5L2dJUk9CZG9mWXNzaDhKKzI1WlhFcWppa1ZQL2JIdTdxaEZVNlMxaGMK"
    }
  }
}
