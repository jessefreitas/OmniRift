# OS
.DS_Store
Thumbs.db

# Claude Code (logs de runtime de hooks)
.claude/*.log

# Serena (cache de estrutura de código por projeto — gerado pelos agentes)
.serena/

# OmniRift runtime por-projeto: relatórios de Saúde + estado dos runs TURBO
# (gerados em tempo de execução dentro do projeto aberto; não comitar).
.omnirift/

# Python (scripts/ — caches de bytecode)
__pycache__/
*.pyc

# Licença OmniRift — chave PRIVADA do keygen (NUNCA comitar)
tools/.omnirift-license.key

# Updater OmniRift — chave PRIVADA de assinatura dos updates (NUNCA comitar).
# A pública vai no tauri.conf.json; a privada assina o build (TAURI_SIGNING_PRIVATE_KEY).
tools/.omnirift-updater.key
tools/.omnirift-updater.key.pub

# Sidecar do OmniCompress — binário por-plataforma, buildado pela CI
# (scripts/build-omnicompress.sh). Não comitar (6MB+, derivado, por-triple).
apps/desktop/src-tauri/binaries/

# OmniRift beta admin token (local; NUNCA commitar)
tools/.omrift-admin-token

# Tauri icon: saídas mobile não usadas (projeto desktop)
apps/desktop/src-tauri/icons/android/
apps/desktop/src-tauri/icons/ios/

# Artefatos de build / distribuição — vão pros Releases, NUNCA pro git (incham o repo)
*.zip
*.AppImage
*.deb
*.exe
*.msi
*.tar.gz

# ref reverse-engineering artifacts (AppImage, extracted squashfs, source ref)
ref/

# ferramenta de scan externa (não versionar — 319MB)
bin/endorctl

# logs de gate de tools locais (sessões de agente) — nunca commitar
tools/**/.gate.log

# conf gerada pelo install-macos-dev.sh
apps/desktop/src-tauri/tauri.dev-install.generated.json
