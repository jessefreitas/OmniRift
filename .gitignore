# Licença OmniRift — chave PRIVADA do keygen (NUNCA comitar)
tools/.omnirift-license.key

# Updater OmniRift — chave PRIVADA de assinatura dos updates (NUNCA comitar).
# A pública vai no tauri.conf.json; a privada assina o build (TAURI_SIGNING_PRIVATE_KEY).
tools/.omnirift-updater.key
tools/.omnirift-updater.key.pub

# Sidecar do OmniCompress — binário por-plataforma, buildado pela CI
# (scripts/build-omnicompress.sh). Não comitar (6MB+, derivado, por-triple).
apps/desktop/src-tauri/binaries/

# OmniRift beta admin token (local; NUNCA commitar)
tools/.omrift-admin-token
